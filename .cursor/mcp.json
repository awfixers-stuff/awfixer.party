{
  "mcpServers": {
    "next-devtools": {
      "command": "bunx",
      "args": [
        "next-devtools-mcp@latest"
      ]
    },
    "shadcn": {
      "command": "bunx",
      "args": [
        "shadcn@latest",
        "mcp"
      ]
    },
    "railway": {
      "command": "npx",
      "args": [
        "-y",
        "@railway/mcp-server"
      ]
    }
  }
}
