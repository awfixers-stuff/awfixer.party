# Clerk (see https://clerk.com/docs and Convex + Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Issuer for Convex JWT validation — same as Clerk Frontend API (OpenID issuer), e.g. https://clerk.example.com
# Set the same value on your Convex deployment (Dashboard → Environment Variables) for convex/auth.config.ts.
CLERK_JWT_ISSUER_DOMAIN=

EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=...
CLERK_SECRET_KEY=...

# Backboard (Nitro BFF at backboard/) — same Convex deployment URL as the web app for read DTOs
BACKBOARD_CONVEX_URL=
# Next.js server-only: origin of the Nitro app for SSR data fetches (no trailing slash). Example: http://127.0.0.1:3001
BACKBOARD_API_BASE=
#
# --- Railway (two services, same project + environment) ---
# 1) Create services from this repo: web (root railway.toml) and backboard (/backboard/railway.toml).
#    In each service: Settings → Config-as-code → path as above. Repository root directory: / for both.
# 2) Name the Nitro service exactly `backboard` so private DNS is `backboard.railway.internal`.
# 3) Web service → Variables → set BACKBOARD_API_BASE using private networking, HTTP (not HTTPS), e.g.:
#      http://${{backboard.RAILWAY_PRIVATE_DOMAIN}}:${{backboard.PORT}}
#    If `${{backboard.PORT}}` is not offered in the UI, add a variable on the backboard service (e.g.
#    BACKBOARD_LISTEN_PORT) matching the port Nitro listens on and reference that instead.
# 4) Backboard service: set BACKBOARD_CONVEX_URL, BACKBOARD_ALLOWED_ORIGINS (your public site origins for browser CORS).
# 5) After `railway.com/new` auto-import, remove or disable staged services for `mobile` and `admin-mobile`
#    (they are excluded from the Railpack context via .dockerignore and omitted from deploy watch paths).
# Comma-separated origins allowed for browser CORS in production (e.g. https://awfixer.party,https://www.awfixer.party)
BACKBOARD_ALLOWED_ORIGINS=

# Convex
NEXT_PUBLIC_CONVEX_URL=
# Optional: explicit `.convex.site` HTTP base (short links use `${this}/r/{code}`). If unset, derived from NEXT_PUBLIC_CONVEX_URL.
NEXT_PUBLIC_CONVEX_SITE_URL=
# Deploy key for CI (e.g. Vercel preview deploys): https://docs.convex.dev/production/hosting
CONVEX_DEPLOY_KEY=
# Local `bun run build` runs `convex deploy --yes` (push to prod). Ensure NEXT_PUBLIC_CONVEX_URL matches the deployment you target (often prod in Vercel).

# Comma-separated Clerk organization IDs that may access /admin and Convex admin functions.
# Must match Convex dashboard env ADMIN_CLERK_ORGANIZATION_IDS.
ADMIN_CLERK_ORGANIZATION_IDS=

# Optional: deep link from Admin → Analytics to your project’s Vercel Analytics page
NEXT_PUBLIC_VERCEL_ANALYTICS_URL=

# TipTap Pro (https://tiptap.dev/docs/guides/pro-extensions) — required for `bun install` (see .bun --bunrc)
TIPTAP_PRO_TOKEN=
