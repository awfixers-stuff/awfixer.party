{
  "$schema": "https://railway.com/railway.schema.json",
  "environments": {},
  "deploy": {
    "registryCredentials": {
      "password": "",
      "username": ""
    },
    "runtime": "V2",
    "restartPolicyType": "ON_FAILURE",
    "startCommand": "bunx next start --hostname :: --port $PORT",
    "region": "US",
    "drainingSeconds": null,
    "preDeployCommand": null,
    "ipv6EgressEnabled": false,
    "numReplicas": null,
    "restartPolicyMaxRetries": 5,
    "sleepApplication": true,
    "healthcheckPath": "/"
  },
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bun install && bun run build",
    "watchPatterns": [
      "/package.json",
      "/bun.lock",
      "/next.config.mjs",
      "/tsconfig.json",
      "/postcss.config.mjs",
      "/proxy.ts",
      "/components.json",
      "/instrumentation.ts",
      "/instrumentation-client.ts",
      "/sentry.server.config.ts",
      "/sentry.edge.config.ts",
      "/vercel.json",
      "/vitest.config.ts",
      "/app/**",
      "/components/**",
      "/convex/**",
      "/lib/**",
      "/hooks/**",
      "/public/**",
      "/scripts/**",
      "/styles/**"
    ]
  }
}
